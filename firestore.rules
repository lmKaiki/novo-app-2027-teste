rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() { return request.auth != null; }
    
    function isOwner(serverId) {
      return isAuthenticated() && get(/databases/$(database)/documents/servers/$(serverId)).data.ownerId == request.auth.uid;
    }

    function isMember(serverId) {
      return isAuthenticated() && exists(/databases/$(database)/documents/servers/$(serverId)/members/$(request.auth.uid));
    }

    function hasPermission(serverId, permission) {
      let memberRole = get(/databases/$(database)/documents/servers/$(serverId)/members/$(request.auth.uid)).data.roleId;
      return isOwner(serverId) || (isMember(serverId) && get(/databases/$(database)/documents/servers/$(serverId)/roles/$(memberRole)).data.permissions[permission] == true);
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Servers collection
    match /servers/{serverId} {
      allow read: if isMember(serverId);
      allow create: if isAuthenticated();
      allow update: if isOwner(serverId);
      
      // Subcollections
      match /channels/{channelId} {
        allow read: if isMember(serverId);
        allow write: if hasPermission(serverId, 'manageChannels');
      }
      
      match /messages/{messageId} {
        allow read: if isMember(serverId);
        allow create: if isMember(serverId) && hasPermission(serverId, 'sendMessages');
      }
      
      match /roles/{roleId} {
        allow read: if isMember(serverId);
        allow write: if hasPermission(serverId, 'manageRoles');
      }
      
      match /members/{memberId} {
        allow read: if isMember(serverId);
        allow write: if hasPermission(serverId, 'kickMembers') || isOwner(serverId);
      }
      
      match /events/{eventId} {
        allow read: if isMember(serverId);
        allow write: if hasPermission(serverId, 'createEvents');
      }
    }
  }
}
